{
  "expo": {
    "name": "Atlas",
    "slug": "frontend",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Record voice notes for site updates",
        "NSCameraUsageDescription": "Capture site photos to log events",
        "NSPhotoLibraryUsageDescription": "Attach photos to site events",
        "NSLocationWhenInUseUsageDescription": "Tag events with site GPS location"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#121212"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#121212"
        }
      ],
      [
        "expo-audio",
        { "microphonePermission": "Record voice notes for site updates" }
      ],
      [
        "expo-camera",
        { "cameraPermission": "Capture site photos to log events" }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Attach photos to site events",
          "cameraPermission": "Capture site photos to log events"
        }
      ],
      [
        "expo-location",
        { "locationAlwaysAndWhenInUsePermission": "Tag events with site GPS location" }
      ]
    ],
    "experiments": { "typedRoutes": true }
  }
}
